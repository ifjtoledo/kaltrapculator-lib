{
  "name": "kaltrapculator-lib",
  "version": "1.0.1",
  "description": "Zero-dependency Web Component that turns any <input> into a calculator-assisted field. Keyboard-first, 3 themes, i18n-ready, 5.9 KB gzipped.",
  "type": "module",
  "main": "./dist/kaltrapculator.umd.js",
  "module": "./dist/kaltrapculator.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/kaltrapculator.es.js",
      "require": "./dist/kaltrapculator.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "demo": "vite",
    "design": "vite --open /design-lab/",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ifjtoledo/kaltrapculator-lib.git"
  },
  "sideEffects": false,
  "keywords": [
    "web-component",
    "custom-element",
    "calculator",
    "input",
    "keyboard",
    "number-format",
    "shadow-dom",
    "a11y",
    "i18n",
    "vanilla-js"
  ],
  "author": "ifjtoledo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ifjtoledo/kaltrapculator-lib/issues"
  },
  "homepage": "https://github.com/ifjtoledo/kaltrapculator-lib#readme",
  "devDependencies": {
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
